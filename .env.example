# =====================================================
# RestoFlow — Environment Variables
# Copy file ini ke .env dan isi sesuai environment kamu
# =====================================================

# ── DATABASE (Supabase) ───────────────────────────────
# Wajib! Gunakan connection string Supabase Pooler.
# Cara dapat:
#   1. Buka dashboard Supabase → Project → Settings → Database
#   2. Scroll ke "Connection Pooling" → pilih "Session mode"
#   3. Copy "Connection string" untuk port 5432 (session pooler)
#   4. Atau pakai port 6543 (transaction pooler) untuk serverless
# 
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Alternative names (hanya perlu salah satu):
# SUPABASE_DB_URL=
# SUPABASE_URL=

# ── JWT SECRETS ───────────────────────────────────────
# Wajib di production! Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── CORS ──────────────────────────────────────────────
# Di production, pisahkan dengan koma.
# Contoh: CORS_ALLOWED_ORIGINS=https://restoflow-ruddy.vercel.app,https://restoflow-app.vercel.app
#
# ⚠️ Kalau tidak diset di production, server akan mengizinkan SEMUA origin
#    (supaya tidak pusing dengan URL Vercel/Railway yang berubah-ubah)

# ── ENVIRONMENT ───────────────────────────────────────
# Railway auto-set NODE_ENV=production
# NODE_ENV=production

# ── PORT ──────────────────────────────────────────────
# Railway auto-inject PORT. Lokal default 3000.
# PORT=3000

# ── GOOGLE GEMINI AI ──────────────────────────────────
# GEMINI_API_KEY=your_api_key_here

# ── FRONTEND URL (untuk Vite) ─────────────────────────
# Set di Vercel dashboard, bukan di sini
# VITE_API_URL=https://restoflow-production-fee9.up.railway.app
